---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Newsletter" description="Weekly analysis of AI, technology, markets, and the signals that matter.">
  <section class="newsletter">
    <div class="nl-card">

      <div class="nl-eyebrow">Weekly Briefing</div>
      <h1 class="nl-h1">Get the<br>briefing.</h1>
      <p class="nl-sub">Weekly analysis of AI, technology, markets, and the signals that matter. No noise. No filler.</p>

      <div class="nl-form">
        <script is:inline async src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="25cc5817-f9f1-4437-925c-a804396f94ce"></script>
      </div>

      <div class="nl-meta">Free · Weekly · No spam</div>

    </div>
  </section>
</BaseLayout>

<style>
.newsletter {
  min-height: 70vh;
  display: grid;
  place-items: center;
  padding: 32px 20px;
}

.nl-card {
  width: 100%;
  max-width: 580px;
  background: var(--bg2);
  border: 1px solid var(--b);
  padding: 48px;
}

.nl-eyebrow {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 16px;
}

.nl-h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 8vw, 80px);
  line-height: .95;
  letter-spacing: .02em;
  color: var(--paper);
  margin-bottom: 16px;
}

.nl-sub {
  font-family: 'Libre Baskerville', serif;
  font-size: 15px;
  font-style: italic;
  color: rgba(245,240,232,.5);
  line-height: 1.7;
  margin-bottom: 32px;
}

.nl-form {
  display: flex;
  gap: 0;
  margin-bottom: 16px;
}

.nl-form input {
  flex: 1;
  background: var(--bg);
  border: 1px solid var(--b);
  border-right: none;
  color: var(--paper);
  padding: 14px 16px;
  font-family: 'Space Mono', monospace;
  font-size: 12px;
  outline: none;
  transition: border-color .2s;
}

.nl-form input:focus {
  border-color: var(--amber);
}

.nl-form input::placeholder {
  color: rgba(245,240,232,.25);
}

.nl-form button {
  background: var(--amber);
  color: var(--ink);
  border: none;
  padding: 14px 22px;
  cursor: pointer;
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  transition: opacity .2s;
  white-space: nowrap;
}

.nl-form button:hover {
  opacity: .85;
}

.nl-meta {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: .08em;
  color: rgba(245,240,232,.2);
  text-transform: uppercase;
}

@media (max-width: 640px) {
  .nl-card { padding: 32px 20px; }
  .nl-form { flex-direction: column; }
  .nl-form input { border-right: 1px solid var(--b); border-bottom: none; }
  .nl-form button { width: 100%; }
}
</style>

