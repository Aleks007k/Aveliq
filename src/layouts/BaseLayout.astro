---
import '../styles.css';
import TickerBar from '../components/TickerBar.astro';
const { title, description, ogImage, ogType, canonical, schema, breadcrumbSchema } = Astro.props;
const siteUrl = 'https://aveliq.com';
const finalOgImage = ogImage ?? `${siteUrl}/og-default.jpg`;
const finalCanonical = canonical ?? Astro.url.href;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} — Aveliq</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={finalCanonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType ?? "website"} />
  <meta property="og:url" content={finalCanonical} />
  <meta property="og:image" content={finalOgImage} />
  <meta property="og:site_name" content="Aveliq" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={finalOgImage} />

  <!-- Schema.org -->
  <Fragment set:html={schema ? `<script type="application/ld+json">${JSON.stringify(schema)}</script>` : ''} />
  <Fragment set:html={breadcrumbSchema ? `<script type="application/ld+json">${JSON.stringify(breadcrumbSchema)}</script>` : ''} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="logo">
    <a href="/" style="display:flex;align-items:center;gap:12px;">
      <svg width="28" height="28" viewBox="0 0 40 40" fill="none">
       <polygon points="20,3 37,20 20,37 3,20" fill="none" stroke="#d4a853" stroke-width="1.8"/>
       <line x1="13" y1="20" x2="16.5" y2="20" stroke="#d4a853" stroke-width="1.8"/>
       <line x1="18" y1="14" x2="18" y2="26" stroke="#d4a853" stroke-width="1.8"/>
       <line x1="20" y1="11" x2="20" y2="29" stroke="#d4a853" stroke-width="1.8"/>
       <line x1="22" y1="14" x2="22" y2="26" stroke="#d4a853" stroke-width="1.8"/>
       <line x1="23.5" y1="20" x2="27" y2="20" stroke="#d4a853" stroke-width="1.8"/>
     </svg>
<div class="logo-name">AVELIQ</div>
    </a>
  </div>
  <ul class="nav-links">
    <a href="/category/ai">AI</a>
    <a href="/category/finance">Finance</a>
    <a href="/category/crypto">Crypto</a>
    <a href="/category/business">Business</a>
    <a href="/category/fintech">Fintech</a>
  </ul>
  <div class="nav-right">Live</div>
</nav>

<!-- TICKER -->
<TickerBar />

<!-- СТРАНИЦА -->
<slot />

<!-- FOOTER -->
<!-- FOOTER -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <div class="footer-logo">
        <svg width="24" height="24" viewBox="0 0 40 40" fill="none">
          <polygon points="20,3 37,20 20,37 3,20" fill="none" stroke="#d4a853" stroke-width="1.8"/>
          <line x1="13" y1="20" x2="16.5" y2="20" stroke="#d4a853" stroke-width="1.8"/>
          <line x1="18" y1="14" x2="18" y2="26" stroke="#d4a853" stroke-width="1.8"/>
          <line x1="20" y1="11" x2="20" y2="29" stroke="#d4a853" stroke-width="1.8"/>
          <line x1="22" y1="14" x2="22" y2="26" stroke="#d4a853" stroke-width="1.8"/>
          <line x1="23.5" y1="20" x2="27" y2="20" stroke="#d4a853" stroke-width="1.8"/>
        </svg>
        <span class="logo-name">AVELIQ</span>
      </div>
      <div class="footer-desc">Signal over noise. Intelligence on AI, finance and fintech.</div>
    </div>
    <div class="footer-links">
      <div class="footer-col">
        <div class="footer-col-t">Markets</div>
        <a href="/category/ai">AI</a>
        <a href="/category/finance">Finance</a>
        <a href="/category/crypto">Crypto</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-t">More</div>
        <a href="/category/business">Business</a>
        <a href="/category/fintech">Fintech</a>
        <a href="/newsletter">Newsletter</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-t">About</div>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="/privacy">Privacy</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© 2026 Aveliq. All rights reserved.</span>
    <span class="footer-bottom-links">
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
    </span>
  </div>
</footer>

</body>
</html>