---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const allArticles = await getCollection('articles');
const authorArticles = allArticles
  .filter((a: CollectionEntry<'articles'>) => a.data.author === 'Alex Reeve')
  .sort((a: CollectionEntry<'articles'>, b: CollectionEntry<'articles'>) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );

const catLabel: Record<string, string> = {
  ai: 'AI', finance: 'Finance', crypto: 'Crypto',
  business: 'Business', fintech: 'Fintech'
};

const siteUrl = 'https://aveliq.net';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Alex Reeve",
  "jobTitle": "Editor",
  "worksFor": {
    "@type": "Organization",
    "name": "Aveliq"
  },
  "url": `${siteUrl}/authors/alex-reeve/`,
  "description": "Editor at Aveliq covering AI, finance, and fintech."
};
---

<BaseLayout
  title="Alex Reeve"
  description="Alex Reeve is Editor at Aveliq, covering artificial intelligence, finance, and fintech."
  canonical={`${siteUrl}/authors/alex-reeve/`}
  schema={personSchema}
>

<div class="author-page">

  <div class="author-hero">
    <div class="author-hero-inner">
      <div class="author-big-av">AR</div>
      <div class="author-hero-text">
        <div class="author-eyebrow">Author</div>
        <h1 class="author-name-h1">Alex Reeve</h1>
        <div class="author-title">Editor · Aveliq</div>
        <p class="author-bio">Alex Reeve covers artificial intelligence, finance, and fintech. His writing focuses on the structural shifts reshaping markets — from autonomous trading systems to embedded finance. Before Aveliq, he spent a decade analysing technology and capital markets.</p>
        <div class="author-stats">
          <div class="author-stat">
            <span class="author-stat-n">{authorArticles.length}</span>
            <span class="author-stat-l">Articles</span>
          </div>
          <div class="author-stat">
            <span class="author-stat-n">5</span>
            <span class="author-stat-l">Categories</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="author-articles">
    <div class="author-articles-label">Latest by Alex Reeve</div>
    {authorArticles.map((a: CollectionEntry<'articles'>, i: number) => (
      <a href={`/articles/${a.id}/`} class="author-row">
        <div class="author-row-n">{String(i + 1).padStart(2, '0')}</div>
        <div class="author-row-body">
          <div class="author-row-cat">{catLabel[a.data.category] ?? a.data.category}</div>
          <h2 class="author-row-h">{a.data.title}</h2>
          <div class="author-row-meta">{a.data.date} · {a.data.readTime} min read</div>
        </div>
      </a>
    ))}
  </div>

</div>

</BaseLayout>

<style>
.author-hero {
  background: var(--bg2);
  border-bottom: 1px solid var(--b);
  padding: 60px 0;
}
.author-hero-inner {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 32px;
  display: flex;
  gap: 32px;
  align-items: flex-start;
}
.author-big-av {
  width: 88px;
  height: 88px;
  background: var(--amber);
  color: var(--ink);
  display: grid;
  place-items: center;
  font-family: 'Space Mono', monospace;
  font-size: 28px;
  font-weight: 700;
  flex-shrink: 0;
}
.author-eyebrow {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 12px;
}
.author-name-h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(44px, 6vw, 72px);
  line-height: .95;
  letter-spacing: .02em;
  color: var(--paper);
  margin-bottom: 8px;
}
.author-title {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  letter-spacing: .08em;
  color: rgba(245,240,232,.4);
  margin-bottom: 20px;
}
.author-bio {
  font-family: 'Libre Baskerville', serif;
  font-size: 16px;
  color: rgba(245,240,232,.65);
  line-height: 1.8;
  max-width: 600px;
  margin-bottom: 24px;
}
.author-stats {
  display: flex;
  gap: 32px;
}
.author-stat {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.author-stat-n {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 32px;
  color: var(--amber);
  line-height: 1;
}
.author-stat-l {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: rgba(245,240,232,.3);
}
.author-articles {
  max-width: 900px;
  margin: 0 auto;
  padding: 48px 32px 80px;
}
.author-articles-label {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 24px;
}
.author-row {
  display: flex;
  gap: 20px;
  padding: 24px 0;
  border-bottom: 1px solid var(--b);
  text-decoration: none;
  transition: background .18s;
}
.author-row:hover { background: var(--dim2); }
.author-row-n {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--amber);
  padding-top: 4px;
  min-width: 28px;
}
.author-row-cat {
  font-family: 'Space Mono', monospace;
  font-size: 8px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 6px;
}
.author-row-h {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 24px;
  letter-spacing: .02em;
  color: var(--paper);
  margin-bottom: 6px;
  transition: color .18s;
}
.author-row:hover .author-row-h { color: var(--amber); }
.author-row-meta {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  color: rgba(245,240,232,.3);
}
@media (max-width: 768px) {
  .author-hero-inner { flex-direction: column; padding: 0 18px; gap: 20px; }
  .author-articles { padding: 32px 18px 60px; }
  .author-big-av { width: 64px; height: 64px; font-size: 22px; }
}
</style>