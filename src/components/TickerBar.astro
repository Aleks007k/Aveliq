---
// TickerBar.astro — живые данные из Cloudflare Worker
// Worker обновляет цены каждые 20 минут
---

<div class="ticker">
  <div class="ticker-label">SIGNALS</div>
  <div class="ticker-scroll">
    <div class="ticker-track" id="tickerTrack">
      <!-- Заглушка пока грузятся данные -->
      <span class="ticker-item"><b>BTC</b> <span class="up">+0.0%</span> $—</span>
      <span class="ticker-item"><b>ETH</b> <span class="up">+0.0%</span> $—</span>
      <span class="ticker-item"><b>SOL</b> <span class="up">+0.0%</span> $—</span>
      <span class="ticker-item"><b>BNB</b> <span class="up">+0.0%</span> $—</span>
      <span class="ticker-item"><b>XRP</b> <span class="up">+0.0%</span> $—</span>
      <span class="ticker-item"><b>NVDA</b> <span class="up">+0.0%</span> $—</span>
      <span class="ticker-item"><b>AAPL</b> <span class="up">+0.0%</span> $—</span>
      <span class="ticker-item"><b>S&amp;P 500</b> <span class="up">+0.0%</span> $—</span>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  var WORKER_URL = 'https://aveliq-ticker.aleks-07k-ua.workers.dev';

  function buildItems(items) {
    return items.concat(items).map(function (item) {
      return '<span class="ticker-item"><b>' + item.label + '</b> ' +
        '<span class="' + item.dir + '">' + item.change + '</span> ' +
        item.price + '</span>';
    }).join('');
  }

  fetch(WORKER_URL)
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (!data.items || !data.items.length) return;
      var track = document.getElementById('tickerTrack');
      if (track) track.innerHTML = buildItems(data.items);
    })
    .catch(function () {
      // если Worker недоступен — заглушка остаётся
    });
})();
</script>