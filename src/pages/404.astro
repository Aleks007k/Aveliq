---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found" description="This page does not exist.">
  <section class="error-page">
    <div class="error-num">404</div>
    <div class="error-label">Page not found</div>
    <p class="error-desc">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="home-link">← Return to homepage</a>
  </section>
</BaseLayout>

<style>
.error-page {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 2rem;
}

.error-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(100px, 20vw, 180px);
  line-height: 1;
  color: rgba(212,168,83,.15);
  letter-spacing: .02em;
  margin-bottom: 0;
}

.error-label {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(24px, 4vw, 40px);
  letter-spacing: .06em;
  color: var(--paper);
  margin-bottom: 16px;
}

.error-desc {
  font-family: 'Libre Baskerville', serif;
  font-size: 15px;
  font-style: italic;
  color: rgba(245,240,232,.4);
  margin-bottom: 36px;
}

.home-link {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  letter-spacing: .1em;
  text-transform: uppercase;
  padding: 12px 24px;
  border: 1px solid var(--amber);
  color: var(--amber);
  text-decoration: none;
  transition: background .2s, color .2s;
}

.home-link:hover {
  background: var(--amber);
  color: var(--ink);
}
</style>