---
import BaseLayout from '../layouts/BaseLayout.astro';

const authors = [
  {
    initials: 'AR',
    name: 'Alex Reeve',
    slug: 'alex-reeve',
    focus: 'AI, business, and macro finance',
    desc: "Lead editorial voice. Covers AI, business, and markets, and writes Aveliq's commercial comparisons and reviews. Cold and concrete from the first line, skeptical of hype, and always takes a position grounded in revenue and unit economics rather than press-release language."
  },
  {
    initials: 'SC',
    name: 'Sophia Chen',
    slug: 'sophia-chen',
    focus: 'Crypto and fintech',
    desc: "Covers cryptocurrencies, tokens, exchanges, DeFi, stablecoins, and fintech rails. Reads price action and on-chain data closely and writes for readers who already understand the market — specific figures, clear stance, no filler."
  },
  {
    initials: 'MH',
    name: 'Marcus Hale',
    slug: 'marcus-hale',
    focus: 'Deep AI',
    desc: "Writes long-form deep dives into how AI works under the hood — models, research, and infrastructure. For readers who want the mechanics, not the surface."
  },
  {
    initials: 'HY',
    name: 'Hanna Yovska',
    slug: 'hanna-yovska',
    focus: 'Finance',
    desc: "Covers personal, institutional, and macro finance with a human angle — what the numbers actually mean for an ordinary person or investor."
  }
];
---

<BaseLayout title="About" description="Aveliq covers AI, finance and fintech. Signal over noise.">
  <section class="about">

    <div class="about-hero">
      <div class="about-eyebrow">About</div>
      <h1 class="about-h1">Signal<br>over noise.</h1>
    </div>

    <div class="about-body">

      <div class="about-block">
        <div class="about-block-label">Mission</div>
        <div class="about-block-content">
          <p>Aveliq covers artificial intelligence, technology, markets, and the ideas shaping the future. Our mission is to filter noise, identify important signals, and deliver clear analysis for curious readers.</p>
          <p>We write for investors, operators, and technologists who need context, not headlines.</p>
        </div>
      </div>

      <div class="about-block">
        <div class="about-block-label">Editorial Standards</div>
        <div class="about-block-content">
          <p>We prioritize accuracy, transparency, and context. Every story is reviewed for clarity and factual consistency. We separate reporting from opinion and update articles when new information becomes available.</p>
          <p>We do not accept payment for editorial coverage. Sponsored content is always clearly labelled.</p>
        </div>
      </div>

      <div class="about-block">
        <div class="about-block-label">How We Work</div>
        <div class="about-block-content">
          <p>Aveliq is AI-assisted. We use AI tools to help research, draft, and structure our articles. Every piece is reviewed by a human before publication — figures are checked against primary sources, and nothing is published on autopilot.</p>
          <p>Our authors are editorial voices, each with a defined focus and a consistent point of view. They are not presented as real individuals, and we do not invent personal histories or credentials for them.</p>
        </div>
      </div>

      <div class="about-block">
        <div class="about-block-label">Authors</div>
        <div class="about-block-content">
          {authors.map((a) => (
            <div class="author-entry">
              <div class="author-card">
                <div class="author-av">{a.initials}</div>
                <div>
                  <a href={`/authors/${a.slug}/`} class="author-name-link">
                    <div class="author-name">{a.name}</div>
                  </a>
                  <div class="author-role">{a.focus}</div>
                </div>
              </div>
              <p class="author-desc">{a.desc}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
.about-hero {
  background: var(--bg2);
  border-bottom: 1px solid var(--b);
  padding: 60px 40px 48px;
}
.about-eyebrow {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 16px;
}
.about-h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 7vw, 88px);
  line-height: .95;
  letter-spacing: .02em;
  color: var(--paper);
}
.about-body {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 40px 80px;
}
.about-block {
  display: grid;
  grid-template-columns: 180px 1fr;
  gap: 40px;
  padding: 48px 0;
  border-bottom: 1px solid var(--b);
}
.about-block-label {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--amber);
  padding-top: 4px;
}
.about-block-content p {
  font-family: 'Libre Baskerville', serif;
  font-size: 16px;
  color: rgba(245,240,232,.7);
  line-height: 1.8;
  margin-bottom: 16px;
}
.about-block-content p:last-child { margin-bottom: 0; }

.author-entry { margin-top: 28px; }
.author-entry:first-child { margin-top: 0; }

.author-card {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 12px;
  padding: 20px;
  background: var(--bg2);
  border: 1px solid var(--b);
}
.author-av {
  width: 44px;
  height: 44px;
  background: var(--amber);
  color: var(--ink);
  display: grid;
  place-items: center;
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  font-weight: 700;
  flex-shrink: 0;
}
.author-name-link { text-decoration: none; }
.author-name-link:hover .author-name { color: var(--amber); }
.author-name {
  font-family: 'Space Mono', monospace;
  font-size: 12px;
  font-weight: 700;
  color: var(--paper);
  margin-bottom: 4px;
  transition: color .18s;
}
.author-role {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  color: rgba(245,240,232,.35);
  letter-spacing: .06em;
}
.author-desc {
  font-family: 'Libre Baskerville', serif;
  font-size: 16px;
  color: rgba(245,240,232,.7);
  line-height: 1.8;
}

@media (max-width: 768px) {
  .about-hero { padding: 40px 20px 32px; }
  .about-body { padding: 0 20px 60px; }
  .about-block { grid-template-columns: 1fr; gap: 16px; }
}
</style>